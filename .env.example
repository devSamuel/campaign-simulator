# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketing_automation
POSTGRES_USER=marketing
POSTGRES_PASSWORD=marketing_secret
DATABASE_URL=postgresql+asyncpg://marketing:marketing_secret@localhost:5432/marketing_automation

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (Celery broker)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
